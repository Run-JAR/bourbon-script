// test_strings.bon

recipe greet(n):
    display("Hello from BourbonScript!")
    plate 0

recipe main():
    display("Starting BourbonScript tests...")
    display("String concatenation:")
    crumble msg = "Bourbon" + " Biscuit"
    display(msg)
    display("Booleans:")
    crumble t = true
    crumble f = false
    display(t)
    display(f)
    display("Logic:")
    display(1 == 1)
    display(1 != 2)
    display(5 > 3)
    greet(0)
    display("Dunked and delicious!")
