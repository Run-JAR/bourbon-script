// test_strings.bon

recipe greet(n: int) -> int:
    display("Hello from BourbonScript!")
    plate 0

recipe main() -> void:
    display("Starting BourbonScript tests...")
    display("String concatenation:")
    crumble msg: str = "Bourbon" + " Biscuit"
    display(msg)
    display("Booleans:")
    crumble t: bool = fresh
    crumble f: bool = stale
    display(t)
    display(f)
    display("Logic:")
    display(1 == 1)
    display(1 != 2)
    display(5 > 3)
    greet(0)
    display("Dunked and delicious!")
